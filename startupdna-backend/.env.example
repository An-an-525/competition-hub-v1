# StartupDNA Backend Environment Variables
# Copy this file as .env and fill in your values

# Server
PORT=3000
JWT_SECRET=startupdna_change_this_to_a_random_string

# MiniMax AI API (required for AI features)
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_ENDPOINT=https://api.minimax.io/v1/text/chatcompletion_v2
MINIMAX_MODEL=MiniMax-Text-01

# Database (optional, defaults to ./data/startupdna.db)
# DB_PATH=./data/startupdna.db
